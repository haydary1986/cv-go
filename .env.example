# Backend Configuration
DB_PATH=cvbuilder.db
PORT=8080

# REQUIRED in production (GIN_MODE=release) - app will refuse to start without these
JWT_SECRET=REPLACE_WITH_RANDOM_64_CHAR_SECRET
AES_KEY=REPLACE_WITH_RANDOM_32_CHAR_KEY

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Admin (optional - auto-generated if not set)
ADMIN_EMAIL=admin@cvbuilder.com
ADMIN_INITIAL_PASSWORD=

# Demo data (set to true only in development)
SEED_DEMO_DATA=false
